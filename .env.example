# Google Cloud Project Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=1

# Cloud Storage Configuration
GCS_BUCKET=fieldops-inspections-bucket

# Google GenAI / ADK Configuration
# Model names must match standard Vertex AI/Gemini endpoints
# Live Audio Dialog Model
DEMO_AGENT_MODEL=gemini-live-2.5-flash-native-audio
# Standard Text/Vision Model
STANDARD_AGENT_MODEL=gemini-2.5-flash

# Port for local server execution
PORT=8080
